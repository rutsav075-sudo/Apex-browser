{
  "name": "apex-browser",
  "private": true,
  "version": "1.1.0",
  "description": "Apex Browser — AI-powered, privacy-first web browser built with Electron & React",
  "author": "Apex Team <apex.org.91@gmail.com>",
  "license": "MIT",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"npm run electron\"",
    "electron": "electron .",
    "build": "vite build && electron-builder --win --x64",
    "build:dir": "vite build && electron-builder --win --x64 --dir",
    "build:portable": "vite build && electron-builder --win --x64 -c.win.target=portable",
    "preview": "vite preview",
    "lint": "eslint src/ --ext .js,.jsx --max-warnings 0",
    "test": "npx playwright test",
    "test:unit": "npx playwright test --project=unit"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@ghostery/adblocker-electron": "^2.14.1",
    "@mlc-ai/web-llm": "^0.2.80",
    "@react-oauth/google": "^0.13.4",
    "cross-fetch": "^4.1.0",
    "dompurify": "^3.3.3",
    "electron-updater": "^6.8.3",
    "firebase": "^12.12.0",
    "framer-motion": "^10.16.4",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.292.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sql.js": "^1.14.1",
    "three": "^0.184.0",
    "unzipper": "^0.12.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "@playwright/test": "^1.59.1",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "playwright": "^1.59.1",
    "prettier": "^3.1.0",
    "sharp": "^0.34.5",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.apex.browser",
    "productName": "Apex Browser",
    "artifactName": "Apex-Browser-Setup-${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/@ghostery/**",
      "node_modules/cross-fetch/**",
      "node_modules/unzipper/**",
      "node_modules/electron-updater/**",
      "node_modules/sql.js/**"
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env",
        "filter": [
          ".env"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "publisherName": "Apex Team",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Apex Browser",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Network;WebBrowser"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "apex-org",
        "repo": "apex-browser"
      }
    ]
  }
}
